{
  "name": "n8n-nodes-maker",
  "version": "1.0.0",
  "description": "n8n community node for Maker/Sky Protocol - Complete DeFi toolkit for DAI, USDS, MKR, SKY, vaults, DSR, sDAI, PSM, governance, and more",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "maker",
    "makerdao",
    "sky",
    "defi",
    "dai",
    "usds",
    "mkr",
    "stablecoin",
    "vault",
    "cdp",
    "dsr",
    "sdai",
    "ethereum",
    "blockchain",
    "crypto"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://velobpa.com",
  "author": {
    "name": "Velocity BPA",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-maker.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/nodes/Maker/Maker.node.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint nodes credentials --ext .ts",
    "lint:fix": "eslint nodes credentials --ext .ts --fix",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MakerNetwork.credentials.js",
      "dist/credentials/MakerGovernance.credentials.js",
      "dist/credentials/Subgraph.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Maker/Maker.node.js",
      "dist/nodes/Maker/MakerTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.4",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "ethers": "^6.11.0",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}